# Server Configuration
PORT=5000
NODE_ENV=development
HTTPS_ENABLED=false

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/litter-detection-db
DB_NAME=litter-detection-db

# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# CORS Configuration (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Camera & Detection Configuration
MIN_DETECTION_CONFIDENCE=0.5
LITTER_DETECTION_THRESHOLD=0.6
PERSON_DETECTION_THRESHOLD=0.5
